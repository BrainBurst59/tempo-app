{
  "name": "tempo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev:mobile": "pnpm --filter @tempo/mobile start",
    "ios": "pnpm --filter @tempo/mobile ios",
    "android": "pnpm --filter @tempo/mobile android",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "ci": "pnpm format && pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "~6.0.3",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "overrides": {
      "@clerk/clerk-react": ">=5.61.6",
      "vite": ">=6.4.3",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0"
    }
  }
}

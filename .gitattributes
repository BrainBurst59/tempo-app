# Normalize line endings to LF in the repo; check out as-is.
* text=auto eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Lockfile: generated, collapse in diffs.
pnpm-lock.yaml linguist-generated=true -diff

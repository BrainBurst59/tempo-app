# TEMPO mobile — public environment example.
# Copy to `apps/mobile/.env` (which is gitignored) and fill in your value.
#
# EXPO_PUBLIC_* variables are inlined into the client bundle at build time and
# are therefore PUBLIC. Only the Clerk *publishable* key belongs here. The Clerk
# *secret* key must NEVER be placed in this app (it lives in services/api).

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_clerk_publishable_key

# Base URL of the TEMPO backend API (services/api). Defaults to localhost for dev.
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# TEMPO API — server-side environment example.
# Copy to `services/api/.env` (gitignored). NEVER commit real secrets.

# One of: development | test | staging | production
NODE_ENV=development

# Port the API listens on.
PORT=3000

# Clerk SECRET key (server-side only — never ships to the mobile app).
# Used to verify session JWTs and perform privileged Clerk operations.
CLERK_SECRET_KEY=sk_test_replace_me_in_an_uncommitted_env_file

# Optional Clerk authorized party / issuer hardening (recommended in prod).
# CLERK_AUTHORIZED_PARTIES=https://your-app.example

# Postgres connection string for the durable store (Prisma).
DATABASE_URL=postgresql://tempo:tempo@localhost:5432/tempo_dev
